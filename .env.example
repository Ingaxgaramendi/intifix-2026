# ==========================================================================
# Plantilla de variables de entorno. Copia este archivo como `.env` y
# rellena los valores reales (el `.env` real NO se versiona en git).
#   cp .env.example .env
# ==========================================================================

# ----- PostgreSQL (Aiven o local) -----
DB_POSTGRES_HOST=
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=intifix_db
DB_POSTGRES_USER=
DB_POSTGRES_PASSWORD=
# SSL: 'require' para Aiven/nube, 'disable' para contenedor local
DB_POSTGRES_SSLMODE=require

# ----- MongoDB Atlas (solo el host del cluster, sin esquema ni base) -----
DB_MONGO_HOST=
DB_MONGO_NAME=Intifix_mongo
DB_MONGO_USER=
DB_MONGO_PASSWORD=
# Alternativa: URI completa para Mongo local (sobreescribe las variables DB_MONGO_*)
# MONGO_URI=mongodb://localhost:27017/intifix_nosql

# ----- Redis (necesario para login / refresh tokens) -----
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
# true para Redis en la nube (Upstash TLS), false para contenedor local
REDIS_SSL=true

# ----- JWT (mínimo 32 bytes / 256 bits aleatorios) -----
# Genera con: openssl rand -base64 48
JWT_SECRET=

# ----- OpenAI (módulo de recomendación IA) -----
OPENAI_API_KEY=

# ----- Cloudinary (almacenamiento de imágenes en la nube) -----
# Si se omiten, se usa almacenamiento local en /uploads/ (solo desarrollo).
cloudinary_cloud_name=
cloudinary_api_key=
cloudinary_api_secret=

# ----- Correo / Gmail SMTP (comprobantes y recuperación de contraseña) -----
# MAIL_PASSWORD = "contraseña de aplicación" de 16 caracteres (NO tu clave normal).
# Generarla en: Cuenta Google > Seguridad > Verificación 2 pasos > Contraseñas de app.
# Si MAIL_USERNAME queda vacío, el envío se omite (no rompe nada).
MAIL_USERNAME=
MAIL_PASSWORD=
# Opcionales (usan valores por defecto si se omiten):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_FROM=              # remitente visible (por defecto = MAIL_USERNAME)
# MAIL_FROM_NAME=INTIFIX

# ----- URL del frontend (usada en links de email de recuperación) -----
# Producción: https://intifix.com  |  Local: http://localhost:5173
APP_FRONTEND_URL=http://localhost:5173
